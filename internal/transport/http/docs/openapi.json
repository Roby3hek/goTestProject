{
  "openapi": "3.0.3",
  "info": {
    "title": "Task Service API",
    "version": "1.1.0",
    "description": "CRUD API для управления задачами с поддержкой периодичности (ежедневные, ежемесячные, чётные/нечётные дни, конкретные даты)."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Tasks",
      "description": "Операции с задачами"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Получить список всех задач",
        "responses": {
          "200": {
            "description": "Список задач",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Task" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Tasks"],
        "summary": "Создать новую задачу (с возможностью периодичности)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTaskRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Задача успешно создана",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Получить задачу по ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Задача",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Tasks"],
        "summary": "Обновить задачу (включая настройки периодичности)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateTaskRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Обновлённая задача",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Удалить задачу",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "204": { "description": "Задача удалена" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Некорректный запрос",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Ресурс не найден",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "CreateTaskRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": { "type": "string", "example": "Ежедневный обзвон пациентов" },
          "description": { "type": "string", "example": "Обзвонить всех пациентов после выписки" },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "recurrence_type": {
            "type": "string",
            "enum": ["none", "daily", "monthly", "even", "odd", "specific"],
            "example": "daily",
            "description": "Тип периодичности задачи"
          },
          "recurrence_interval": {
            "type": "integer",
            "minimum": 1,
            "example": 1,
            "description": "Для daily: каждые N дней"
          },
          "recurrence_day_of_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31,
            "example": 15,
            "description": "Для monthly: число месяца"
          },
          "specific_dates": {
            "type": "string",
            "example": "2026-04-10,2026-04-25,2026-05-05",
            "description": "Для specific: даты через запятую в формате YYYY-MM-DD"
          },
          "start_date": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01T00:00:00Z",
            "description": "Дата начала действия периодичности (обязательна при recurrence_type != none)"
          },
          "end_date": {
            "type": "string",
            "format": "date-time",
            "example": "2026-12-31T00:00:00Z",
            "nullable": true,
            "description": "Дата окончания периодичности (опционально)"
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": ["title", "status"],
        "properties": {
          "title": { "type": "string", "example": "Ежедневный обзвон пациентов" },
          "description": { "type": "string", "example": "Обзвонить всех пациентов после выписки" },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "in_progress"
          },
          "recurrence_type": {
            "type": "string",
            "enum": ["none", "daily", "monthly", "even", "odd", "specific"],
            "example": "monthly"
          },
          "recurrence_interval": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "recurrence_day_of_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31,
            "example": 5
          },
          "specific_dates": {
            "type": "string",
            "example": "2026-04-15,2026-05-20"
          },
          "start_date": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-01T00:00:00Z"
          },
          "end_date": {
            "type": "string",
            "format": "date-time",
            "nullable": true,
            "example": null
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 1 },
          "title": { "type": "string", "example": "Ежедневный обзвон пациентов" },
          "description": { "type": "string", "example": "Обзвонить всех пациентов после выписки" },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "created_at": { "type": "string", "format": "date-time", "example": "2026-04-06T12:00:00Z" },
          "updated_at": { "type": "string", "format": "date-time", "example": "2026-04-06T12:00:00Z" },
          "recurrence": {
            "type": "object",
            "nullable": true,
            "properties": {
              "recurrence_type": {
                "type": "string",
                "enum": ["none", "daily", "monthly", "even", "odd", "specific"],
                "example": "daily"
              },
              "recurrence_interval": { "type": "integer", "example": 1 },
              "recurrence_day_of_month": { "type": "integer", "nullable": true, "example": 15 },
              "specific_dates": { "type": "string", "nullable": true, "example": "2026-04-10,2026-04-25" },
              "start_date": { "type": "string", "format": "date-time", "example": "2026-04-01T00:00:00Z" },
              "end_date": { "type": "string", "format": "date-time", "nullable": true, "example": null }
            }
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "invalid recurrence_type" }
        }
      }
    }
  }
}